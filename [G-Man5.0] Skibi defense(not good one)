-- Variables
getgenv().autoSkip = false
getgenv().autoFarm = false
local player = game:GetService("Players").LocalPlayer
local towerCFrame = CFrame.new(-88.6019515991211, 3.1293256282806396, 33.49143600463867, 1, -0.0000018196407154391636, -0.00003965427094954066, 0.0000018200940985479974, 1, 0.000011433176950959023, 0.00003965424912166782, -0.000011433248801040463, 1)

-- Correct tower names (case-sensitive)
local TOWERS = {
    LargeSpeakerTV = "Large Speaker TV Man",
    Zombie1 = "Zombie Dark Speakerman",
    Zombie2 = "Zombie Dark Speakerman 2",
    Zombie3 = "Zombie Dark Speakerman 3",
    ZombieMax = "Zombie Dark Speakerman Max"
}

-- Function to get player's current money from leaderstats (排行榜)
local function getMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local money = leaderstats:FindFirstChild("Money") or 
                      leaderstats:FindFirstChild("Cash") or 
                      leaderstats:FindFirstChild("Coins") or
                      leaderstats:FindFirstChild("💰")
        if money then
            return money.Value
        end
    end
    
    local stats = player:FindFirstChild("Stats")
    if stats then
        local money = stats:FindFirstChild("Money")
        if money then
            return money.Value
        end
    end
    
    return nil
end

-- Function to check if we have enough money
local function hasEnoughMoney(towerName)
    local currentMoney = getMoney()
    if not currentMoney then
        return true
    end
    
    local towerCosts = {
        [TOWERS.LargeSpeakerTV] = 600,
        [TOWERS.Zombie1] = 1250,
        [TOWERS.Zombie2] = 3500,
        [TOWERS.Zombie3] = 6000,
        [TOWERS.ZombieMax] = 20000
    }
    
    local cost = towerCosts[towerName] or 1000
    local hasMoney = currentMoney >= cost
    
    if not hasMoney then
        print(string.format("💰 Not enough money! Need: %d, Have: %d - Waiting...", cost, currentMoney))
    end
    
    return hasMoney
end

-- Function to wait for money
local function waitForMoney(towerName, timeout)
    timeout = timeout or 60
    local startTime = tick()
    
    while tick() - startTime < timeout do
        if hasEnoughMoney(towerName) then
            return true
        end
        task.wait(1)
    end
    
    return false
end

-- Function to check if tower placement is available
local function canPlaceTower()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local functions = replicatedStorage:FindFirstChild("Functions")
    
    if functions then
        local spawnTower = functions:FindFirstChild("SpawnTower")
        if spawnTower then
            return true
        end
    end
    
    return false
end

-- Function to wait until tower placement is ready
local function waitForTowerPlacement(timeout)
    timeout = timeout or 30
    local startTime = tick()
    
    print("Waiting for tower placement to become available...")
    
    while tick() - startTime < timeout do
        if canPlaceTower() then
            print("✓ Tower placement is now available!")
            return true
        end
        task.wait(0.5)
    end
    
    print("⚠ Timeout waiting for tower placement")
    return false
end

-- Function to spawn a tower
local function spawnTower(towerName, maxRetries)
    maxRetries = maxRetries or 3
    
    for attempt = 1, maxRetries do
        if not canPlaceTower() then
            waitForTowerPlacement(5)
        end
        
        if not hasEnoughMoney(towerName) then
            waitForMoney(towerName, 30)
            if not hasEnoughMoney(towerName) then
                return false
            end
        end
        
        local success, result = pcall(function()
            return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(towerName, towerCFrame)
        end)
        
        if success then
            local money = getMoney()
            print(string.format("✓ Spawned: %s (Money left: %d)", towerName, money or 0))
            return true
        else
            print(string.format("✗ Attempt %d/%d failed for %s: %s", attempt, maxRetries, towerName, tostring(result)))
            task.wait(1)
        end
    end
    
    return false
end

-- Function to upgrade zombie through levels
local function upgradeZombieToMax()
    if not spawnTower(TOWERS.Zombie1) then
        return false
    end
    task.wait(0.8)
    
    if not spawnTower(TOWERS.Zombie2) then
        return false
    end
    task.wait(0.8)
    
    if not spawnTower(TOWERS.Zombie3) then
        return false
    end
    task.wait(0.8)
    
    if not spawnTower(TOWERS.ZombieMax) then
        return false
    end
    
    return true
end

-- Function to place Max level zombie directly
local function placeMaxZombie()
    return spawnTower(TOWERS.ZombieMax)
end

-- Function to vote for map
local function voteForMap()
    print("Voting for Toilet Base map...")
    
    for i = 1, 3 do
        local args1 = {player, "Toilet Base"}
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("PlayerId"):FireServer(unpack(args1))
        end)
        
        task.wait(0.3)
        
        local args2 = {"Toilet Base"}
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("VoteForMap"):FireServer(unpack(args2))
        end)
        
        task.wait(0.5)
    end
    
    print("✓ Map vote sent for Toilet Base")
end

