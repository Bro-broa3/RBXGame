}

-- Tower costs
local TOWER_COSTS = {
    [TOWERS.LargeSpeakerTV] = 600,
    [TOWERS.Zombie1] = 1250,
    [TOWERS.Zombie2] = 3500,
    [TOWERS.Zombie3] = 6000,
    [TOWERS.ZombieMax] = 20000
}

-- Function to get player's current money
local function getMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local money = leaderstats:FindFirstChild("Money") or 
                      leaderstats:FindFirstChild("Cash") or 
                      leaderstats:FindFirstChild("Coins") or
                      leaderstats:FindFirstChild("💰")
        if money then
            return money.Value
        end
    end
    return nil
end

-- Function to check if we have enough money
local function hasEnoughMoney(towerName)
    local currentMoney = getMoney()
    if not currentMoney then
        return true
    end
    
    local cost = TOWER_COSTS[towerName] or 1000
    return currentMoney >= cost
end

-- Function to wait for money
local function waitForMoney(towerName, timeout)
    timeout = timeout or 60
    local startTime = tick()
    
    while tick() - startTime < timeout do
        if hasEnoughMoney(towerName) then
            return true
        end
        task.wait(1)
    end
    
    return false
end

-- Function to find a tower in Workspace
local function findTower(towerName)
    local towersFolder = workspace:FindFirstChild("Towers")
    if towersFolder then
        for _, tower in ipairs(towersFolder:GetChildren()) do
            if tower.Name == towerName then
                return tower
            end
        end
    end
    return nil
end

-- Function to get the current level of zombie tower
local function getZombieLevel()
    local levels = {
        [TOWERS.ZombieMax] = 4,
        [TOWERS.Zombie3] = 3,
        [TOWERS.Zombie2] = 2,
        [TOWERS.Zombie1] = 1
    }
    
    for towerName, level in pairs(levels) do
        local tower = findTower(towerName)
        if tower then
            return level, towerName, tower
        end
    end
    
    return 0, nil, nil
end

-- Function to click on a tower's position
local function clickOnTower(tower)
    if not tower then
        return false
    end
    
    print(string.format("  Clicking on tower: %s", tower.Name))
    
    -- Get the tower's position
    local position = tower.Position
    local screenPoint = nil
    
    -- Try to get screen position
    local camera = workspace.CurrentCamera
    if camera then
        screenPoint = camera:WorldToScreenPoint(position)
    end
    
    if screenPoint then
        -- Method 1: Simulate mouse click at screen position
        local x, y = screenPoint.X, screenPoint.Y
        
        -- Create mouse event
        local mouseEvent = {
            x = x,
            y = y,
            UserInputType = Enum.UserInputType.MouseButton1
        }
        
        pcall(function()
            -- Fire click on the tower
            game:GetService("UserInputService"):MouseButton1Click(mouseEvent)
        end)
        
        task.wait(0.2)
        print(string.format("  ✓ Clicked at position: %.0f, %.0f", x, y))
        return true
    else
        -- Method 2: Use fireclickdetector on the tower
        local clickDetector = tower:FindFirstChildOfClass("ClickDetector")
        if clickDetector then
            pcall(function()
                clickDetector:FireClick(player)
            end)
            task.wait(0.2)
            print("  ✓ Fired ClickDetector")
            return true
        end
        
        -- Method 3: Try to find any click detector in descendants
        for _, child in ipairs(tower:GetDescendants()) do
            if child:IsA("ClickDetector") then
                pcall(function()
                    child:FireClick(player)
                end)
                task.wait(0.2)
                print("  ✓ Fired ClickDetector from child")
                return true
            end
        end
        
        print("  ⚠ Could not click on tower")
        return false
    end
end

-- Function to click upgrade button in UI
local function clickUpgradeButton()
    print("  Clicking upgrade button...")
    
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then
        print("  ⚠ No PlayerGui found")
        return false
    end
    
    -- Search for upgrade button
    local upgradeButton = nil
    
    local function searchForButton(gui)
        for _, child in ipairs(gui:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local name = child.Name:lower()
                if name:find("upgrade") or name:find("level") or name:find("evolve") or name:find("plus") then
                    upgradeButton = child
                    return true
                end
            end
            if searchForButton(child) then
                return true
            end
        end
        return false
    end
    
    searchForButton(playerGui)
    
    if upgradeButton then
        -- Click the button
        pcall(function()
            upgradeButton:FireClick()
            upgradeButton:FireMouseButton1Click()
        end)
        task.wait(0.3)
        print(string.format("  ✓ Clicked upgrade button: %s", upgradeButton.Name))
        return true
    end
    
    -- Try to find upgrade remote if no UI button
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    
    if events then
        local upgradeRemotes = {"UpgradeTower", "TowerUpgrade", "Upgrade", "UpgradeUnit"}
        for _, remoteName in ipairs(upgradeRemotes) do
            local remote = events:FindFirstChild(remoteName)
            if remote then
                pcall(function()
                    remote:FireServer()
                end)
                task.wait(0.3)
                print(string.format("  ✓ Fired upgrade remote: %s", remoteName))
                return true
            end
        end
    end
    
    print("  ⚠ Could not find upgrade button or remote")
    return false
end

-- Function to spawn a tower (for placing new towers)
local function spawnTower(towerName, maxRetries)
    maxRetries = maxRetries or 3
    
    for attempt = 1, maxRetries do
        if not hasEnoughMoney(towerName) then
            print(string.format("  Waiting for money for %s...", towerName))
            waitForMoney(towerName, 30)
            if not hasEnoughMoney(towerName) then
                return false
            end
        end
        
        local moneyBefore = getMoney()
        
        local success, result = pcall(function()
            return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(towerName, towerCFrame)
        end)
        
        task.wait(2)
        
        local moneyAfter = getMoney()
        
        if success and moneyAfter and moneyAfter < moneyBefore then
            print(string.format("  ✓ Spawned: %s (Money spent: %d)", towerName, moneyBefore - moneyAfter))
            task.wait(1)
            return true
        elseif success then
            print(string.format("  ⚠ Spawn called but money unchanged"))
            task.wait(2)
        else
            print(string.format("  ✗ Attempt %d/%d failed: %s", attempt, maxRetries, tostring(result)))
            task.wait(2)
        end
    end
    
    return false
end

-- Function to upgrade zombie using click on tower and click upgrade button
local function upgradeZombie()
    local currentLevel, currentTowerName, currentTower = getZombieLevel()
    
    if currentLevel >= 4 then
        print("  Zombie is already max level!")
        return true
    end
    
    print(string.format("  Current zombie level: %d (%s)", currentLevel, currentTowerName or "None"))
    
    if not currentTower then
        print("  No zombie tower found to upgrade!")
        return false
    end
    
    -- Check if we have enough money for next level
    local nextLevel = currentLevel + 1
    local nextTowerName = nil
    
    if nextLevel == 2 then
        nextTowerName = TOWERS.Zombie2
    elseif nextLevel == 3 then
        nextTowerName = TOWERS.Zombie3
    elseif nextLevel == 4 then
        nextTowerName = TOWERS.ZombieMax
    end
    
    if nextTowerName and not hasEnoughMoney(nextTowerName) then
        local needed = TOWER_COSTS[nextTowerName]
        local current = getMoney()
        print(string.format("  Not enough money for %s (Need: %d, Have: %d)", nextTowerName, needed, current or 0))
        return false
    end
    
    -- Step 1: Click on the tower to select it
    if not clickOnTower(currentTower) then
        print("  Failed to click on tower")
        return false
    end
    
    task.wait(0.5)
    
    -- Step 2: Click upgrade button
    if not clickUpgradeButton() then
        print("  Failed to click upgrade button")
        return false
    end
    
    task.wait(2)
    
    -- Step 3: Verify upgrade worked
    local newLevel, newTowerName = getZombieLevel()
    
    if newLevel > currentLevel then
        print(string.format("  ✓ Successfully upgraded to level %d (%s)!", newLevel, newTowerName))
        return true
    else
        print(string.format("  ⚠ Upgrade failed - still at level %d", currentLevel))
        return false
    end
end

