-- Auto Skip Toggle
MainTab:CreateToggle({
    Name = "Auto Skip",
    CurrentValue = false,
    Callback = function(Value)
        getgenv().autoSkip = Value
        if Value then
            task.spawn(function()
                while getgenv().autoSkip do
                    pcall(function()
                        local args = {"Skip"}
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("SkipVote"):FireServer(unpack(args))
                    end)
                    task.wait(1)
                end
            end)
        end
    end
})

-- Auto Farm Toggle
MainTab:CreateToggle({
    Name = "Auto Farm",
    CurrentValue = false,
    Callback = function(Value)
        getgenv().autoFarm = Value
        if Value then
            task.spawn(function()
                while getgenv().autoFarm do
                    -- PHASE 1: Wait for lobby
                    print("Waiting for lobby...")
                    task.wait(3)
                    
                    -- PHASE 2: Vote for map (Toilet Base)
                    print("Voting for Toilet Base map...")
                    
                    local mapArgs1 = {"Toilet Base"}
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("VoteForMap"):FireServer(unpack(mapArgs1))
                    end)
                    
                    task.wait(0.5)
                    
                    local mapArgs2 = {game:GetService("Players").LocalPlayer, "Toilet Base"}
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("PlayerId"):FireServer(unpack(mapArgs2))
                    end)
                    
                    task.wait(2)
                    
                    -- PHASE 3: Vote for difficulty (Insane)
                    print("Voting for Insane difficulty...")
                    
                    local diffArgs1 = {"Insane"}
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("VoteForMap"):FireServer(unpack(diffArgs1))
                    end)
                    
                    task.wait(0.5)
                    
                    local diffArgs2 = {game:GetService("Players").LocalPlayer, "Insane"}
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("PlayerId"):FireServer(unpack(diffArgs2))
                    end)
                    
                    task.wait(3)
                    
                    -- PHASE 4: Wait for map to load and start game
                    print("Waiting for map to load...")
                    task.wait(5)
                    
                    print("Starting game...")
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("BeginGame"):FireServer()
                    end)
                    
                    -- PHASE 5: Wait for game to fully start
                    print("Waiting for game to start...")
                    task.wait(5)
                    
                    -- PHASE 6: Change game speed
                    print("Setting game speed to 2x...")
                    local speedArgs = {"2"}
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("ChangeTimeScale"):FireServer(unpack(speedArgs))
                    end)
                    
                    task.wait(2)
                    
                    -- PHASE 7: Place early tower (Large Speaker Tv Man)
                    print("Placing Large Speaker Tv Man...")
                    local towerCFrame = CFrame.new(-88.6019515991211, 3.1293256282806396, 33.49143600463867, 1, -0.0000018196407154391636, -0.00003965427094954066, 0.0000018200940985479974, 1, 0.000011433176950959023, 0.00003965424912166782, -0.000011433248801040463, 1)
                    
                    local firstTowerArgs = {
                        "Large Speaker Tv Man",
                        towerCFrame
                    }
                    
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(unpack(firstTowerArgs))
                    end)
                    
                    task.wait(2)
                    
                    -- PHASE 8: Place and upgrade Zombie Dark Speakerman towers
                    print("Starting Zombie Dark Speakerman placement and upgrade...")
                    
                    -- Place initial Zombie Dark Speakerman
                    local zombieTowerArgs = {
                        "Zombie Dark Speakerman",
                        towerCFrame
                    }
                    
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(unpack(zombieTowerArgs))
                    end)
                    
                    task.wait(1)
                    
                    -- Upgrade Zombie Dark Speakerman through all levels
                    -- Level 1 to Level 2
                    print("Upgrading to Zombie Dark Speakerman 2...")
                    upgradeTower("Zombie Dark Speakerman", 2)
                    task.wait(1)
                    
                    -- Level 2 to Level 3
                    print("Upgrading to Zombie Dark Speakerman 3...")
                    upgradeTower("Zombie Dark Speakerman 2", 3)
                    task.wait(1)
                    
                    -- Level 3 to Max
                    print("Upgrading to Zombie Dark Speakerman Max...")
                    upgradeTower("Zombie Dark Speakerman 3", "Max")
                    task.wait(1)
                    
                    -- Continue placing more Zombie Dark Speakerman towers and upgrading them
                    local towerCount = 1
                    
                    while getgenv().autoFarm do
                        -- Place new Zombie Dark Speakerman
                        local newZombieArgs = {
                            "Zombie Dark Speakerman",
                            towerCFrame
                        }
                        
                        pcall(function()
                            game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(unpack(newZombieArgs))
                        end)
                        
                        towerCount = towerCount + 1
                        print("Placed Zombie Dark Speakerman #" .. towerCount)
                        task.wait(0.5)
                        
                        -- Upgrade it to Max level
                        upgradeTower("Zombie Dark Speakerman", 2)
                        task.wait(0.3)
                        upgradeTower("Zombie Dark Speakerman 2", 3)
                        task.wait(0.3)
                        upgradeTower("Zombie Dark Speakerman 3", "Max")
                        task.wait(0.3)
                        
                        print("Upgraded Zombie Dark Speakerman #" .. towerCount .. " to Max")
                        task.wait(1)
                    end
                end
            end)
        end
    end
})

