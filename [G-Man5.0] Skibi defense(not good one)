-- Function to check if map voting is available
local function canVoteMap()
    -- Try to find vote UI or check if vote remote is available
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    
    if events then
        local voteForMap = events:FindFirstChild("VoteForMap")
        local playerId = events:FindFirstChild("PlayerId")
        
        -- If both remotes exist, voting might be available
        if voteForMap and playerId then
            return true
        end
    end
    
    -- Check for vote UI in PlayerGui
    local playerGui = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        -- Look for any vote-related GUI (you may need to adjust these names)
        for _, gui in ipairs(playerGui:GetChildren()) do
            if gui.Name:lower():find("vote") or gui.Name:lower():find("map") then
                return true
            end
        end
    end
    
    return false
end

-- Function to check if difficulty voting is available
local function canVoteDifficulty()
    -- Similar to map voting check
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    
    if events then
        local voteForMap = events:FindFirstChild("VoteForMap")
        local playerId = events:FindFirstChild("PlayerId")
        
        if voteForMap and playerId then
            return true
        end
    end
    
    return false
end

-- Function to check if game can be started
local function canStartGame()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    
    if events then
        local beginGame = events:FindFirstChild("BeginGame")
        if beginGame then
            return true
        end
    end
    
    return false
end

-- Function to wait until a condition is met with timeout
local function waitForCondition(condition, timeout, checkInterval)
    timeout = timeout or 30
    checkInterval = checkInterval or 0.5
    local elapsed = 0
    
    while elapsed < timeout do
        if condition() then
            return true
        end
        task.wait(checkInterval)
        elapsed = elapsed + checkInterval
    end
    
    return false
end

