                        end
                        
                        if not placed then
                            print("  Waiting 2 seconds before retry...")
                            task.wait(2)
                        end
                    end
                    
                    if placed then
                        print("✓ Large Speaker TV Man placed successfully!")
                    else
                        print("⚠ Failed to place Large Speaker TV Man, continuing with zombies...")
                    end
                    
                    task.wait(2)
                    
                    -- PHASE 8: Spam place and upgrade Zombie Dark Speakerman towers
                    print(string.rep("=", 50))
                    print("=== Starting Zombie Dark Speakerman Farm ===")
                    print("Costs: Level1=1250, Level2=3500, Level3=6000, Max=20000")
                    print(string.rep("=", 50))
                    
                    local zombieCount = 0
                    local successfulUpgrades = 0
                    local failedAttempts = 0
                    
                    while getgenv().autoFarm do
                        zombieCount = zombieCount + 1
                        print(string.rep("-", 40))
                        print("Zombie #" .. zombieCount .. " - Attempting to place and upgrade...")
                        
                        local money = getMoney()
                        print(string.format("💰 Current money: %d", money or 0))
                        
                        if not canPlaceTower() then
                            print("⚠ Tower placement not available, waiting...")
                            waitForTowerPlacement(10)
                        end
                        
                        if upgradeZombieToMax() then
                            successfulUpgrades = successfulUpgrades + 1
                            print(string.format("✓ Success! Total fully upgraded zombies: %d", successfulUpgrades))
                            print(string.format("  Failed attempts: %d", failedAttempts))
                            task.wait(1)
                        else
                            failedAttempts = failedAttempts + 1
                            print(string.format("⚠ Failed to upgrade zombie #%d", zombieCount))
                            print(string.format("  Failed: %d, Success: %d", failedAttempts, successfulUpgrades))
                            task.wait(3)
                        end
                        
                        task.wait(0.5)
                        
                        if zombieCount % 20 == 0 then
                            print(string.rep("=", 40))
                            print("STATS - Zombies attempted: " .. zombieCount)
                            print("STATS - Fully upgraded: " .. successfulUpgrades)
                            print("STATS - Failed: " .. failedAttempts)
                            print("STATS - Success rate: " .. math.floor((successfulUpgrades / zombieCount) * 100) .. "%")
                            print(string.rep("=", 40))
                        end
                        
                        -- After 50 zombies, switch to placing Max directly for speed
                        if zombieCount >= 50 and successfulUpgrades > 40 then
