-- Function to exit and replay game
local function exitAndReplay()
    print("Game ended, exiting and replaying...")
    
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("ExitGame"):FireServer()
    end)
    
    task.wait(2)
    
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("VoteReplay"):FireServer()
    end)
    
    print("✓ Exit and replay sent")
    task.wait(3)
end

