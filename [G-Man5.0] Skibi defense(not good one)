-- Correct tower names (case-sensitive)
local TOWERS = {
    LargeSpeakerTV = "Large Speaker TV Man",
    Zombie1 = "Zombie Dark Speakerman",
    Zombie2 = "Zombie Dark Speakerman 2",
    Zombie3 = "Zombie Dark Speakerman 3",
    ZombieMax = "Zombie Dark Speakerman max"
}

-- Tower costs
local TOWER_COSTS = {
    [TOWERS.LargeSpeakerTV] = 600,
    [TOWERS.Zombie1] = 1250,
    [TOWERS.Zombie2] = 3500,
    [TOWERS.Zombie3] = 6000,
    [TOWERS.ZombieMax] = 20000
}

-- Function to get player's current money
local function getMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local money = leaderstats:FindFirstChild("Money") or 
                      leaderstats:FindFirstChild("Cash") or 
                      leaderstats:FindFirstChild("Coins") or
                      leaderstats:FindFirstChild("💰")
        if money then
            return money.Value
        end
    end
    return nil
end

-- Function to check if we have enough money
local function hasEnoughMoney(towerName)
    local currentMoney = getMoney()
    if not currentMoney then
        return true
    end
    
    local cost = TOWER_COSTS[towerName] or 1000
    return currentMoney >= cost
end

-- Function to wait for money
local function waitForMoney(towerName, timeout)
    timeout = timeout or 60
    local startTime = tick()
    
    while tick() - startTime < timeout do
        if hasEnoughMoney(towerName) then
            return true
        end
        task.wait(1)
    end
    
    return false
end

-- Function to find a tower in Workspace
local function findTower(towerName)
    local towersFolder = workspace:FindFirstChild("Towers")
    if towersFolder then
        for _, tower in ipairs(towersFolder:GetChildren()) do
            if tower.Name == towerName then
                return tower
            end
        end
    end
    return nil
end

-- Function to get all towers of a specific type
local function getAllTowers(towerName)
    local towers = {}
    local towersFolder = workspace:FindFirstChild("Towers")
    if towersFolder then
        for _, tower in ipairs(towersFolder:GetChildren()) do
            if tower.Name == towerName then
                table.insert(towers, tower)
            end
        end
    end
    return towers
end

-- Function to get the current level of zombie tower
local function getZombieLevel()
    local levels = {
        [TOWERS.ZombieMax] = 4,
        [TOWERS.Zombie3] = 3,
        [TOWERS.Zombie2] = 2,
        [TOWERS.Zombie1] = 1
    }
    
    for towerName, level in pairs(levels) do
        local tower = findTower(towerName)
        if tower then
            return level, towerName, tower
        end
    end
    
    return 0, nil, nil
end

-- Function to select/click a tower
local function selectTower(tower)
    if not tower then
        return false
    end
    
    print(string.format("  Selecting tower: %s", tower.Name))
    
    -- Method 1: Fire the Click event on the tower
    local clickEvent = tower:FindFirstChild("ClickDetector")
    if clickEvent then
        pcall(function()
            clickEvent:FireClick(player)
        end)
        task.wait(0.3)
        return true
    end
    
    -- Method 2: Look for a ClickDetector in the tower's children
    for _, child in ipairs(tower:GetChildren()) do
        if child:IsA("ClickDetector") then
            pcall(function()
                child:FireClick(player)
            end)
            task.wait(0.3)
            return true
        end
    end
    
    -- Method 3: Try to find a selection remote
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    if events then
        local selectTower = events:FindFirstChild("SelectTower") or events:FindFirstChild("TowerSelected")
        if selectTower then
            pcall(function()
                selectTower:FireServer(tower)
            end)
            task.wait(0.3)
            return true
        end
    end
    
    print("  ⚠ Could not find way to select tower")
    return false
end

-- Function to upgrade selected tower
local function upgradeSelectedTower()
    print("  Attempting to upgrade selected tower...")
    
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local events = replicatedStorage:FindFirstChild("Events")
    
    -- Try different upgrade remotes
    local upgradeRemotes = {
        "UpgradeTower",
        "TowerUpgrade", 
        "Upgrade",
        "UpgradeUnit"
    }
    
    for _, remoteName in ipairs(upgradeRemotes) do
        if events and events:FindFirstChild(remoteName) then
            pcall(function()
                events[remoteName]:FireServer()
            end)
            task.wait(0.3)
            return true
        end
        
        local functions = replicatedStorage:FindFirstChild("Functions")
        if functions and functions:FindFirstChild(remoteName) then
            pcall(function()
                functions[remoteName]:InvokeServer()
            end)
            task.wait(0.3)
            return true
        end
    end
    
    -- Method 2: Try to find a UI button or something
    print("  ⚠ Could not find upgrade remote")
    return false
end

-- Function to place a new tower
local function spawnTower(towerName, maxRetries)
    maxRetries = maxRetries or 3
    
    for attempt = 1, maxRetries do
        if not hasEnoughMoney(towerName) then
            print(string.format("  Waiting for money for %s...", towerName))
            waitForMoney(towerName, 30)
            if not hasEnoughMoney(towerName) then
                return false
            end
        end
        
        local moneyBefore = getMoney()
        
        local success, result = pcall(function()
            return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(towerName, towerCFrame)
        end)
        
        task.wait(2)
        
        local moneyAfter = getMoney()
        
        if success and moneyAfter and moneyAfter < moneyBefore then
            print(string.format("  ✓ Spawned: %s (Money spent: %d)", towerName, moneyBefore - moneyAfter))
            task.wait(1)
            return true
        elseif success then
            print(string.format("  ⚠ Spawn called but money unchanged"))
            task.wait(3)
        else
            print(string.format("  ✗ Attempt %d/%d failed: %s", attempt, maxRetries, tostring(result)))
            task.wait(3)
        end
    end
    
    return false
end

-- Function to upgrade zombie through clicking and upgrading
local function upgradeZombieToMax()
    local currentLevel, currentTowerName, currentTower = getZombieLevel()
    
    if currentLevel >= 4 then
        print("  Zombie is already max level!")
        return true
    end
    
    print(string.format("  Current zombie level: %d (%s)", currentLevel, currentTowerName or "None"))
    
    if not currentTower then
        print("  No zombie tower found to upgrade!")
        return false
    end
    
    -- Select the tower
    if not selectTower(currentTower) then
        print("  Failed to select tower")
        return false
    end
    
    task.wait(0.5)
    
    -- Upgrade the selected tower
    if upgradeSelectedTower() then
        print("  Upgrade command sent!")
        task.wait(2)
        
        -- Check if upgrade worked by looking for new tower
        local newLevel, newTowerName = getZombieLevel()
        if newLevel > currentLevel then
            print(string.format("  ✓ Successfully upgraded to level %d!", newLevel))
            return true
        else
            print("  ⚠ Upgrade may have failed, level unchanged")
            return false
        end
    else
        print("  Failed to upgrade")
        return false
    end
end

