                    task.wait(2)
                    
                    -- PHASE 7: Place Large Speaker TV Man (cost 600) - FIXED NAME
                    print(string.rep("-", 40))
                    print("Placing Large Speaker TV Man (Cost: 600)...")
                    
                    local moneyBefore = getMoney()
                    print(string.format("💰 Current money: %d", moneyBefore or 0))
                    
                    local placed = false
                    local retryCount = 0
                    
                    while not placed and retryCount < 10 and getgenv().autoFarm do
                        retryCount = retryCount + 1
                        print("Attempt " .. retryCount .. "/10 to place Large Speaker TV Man...")
                        
                        if waitForMoney(TOWERS.LargeSpeakerTV, 15) then
