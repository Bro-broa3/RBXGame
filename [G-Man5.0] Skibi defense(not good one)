-- Correct tower names (case-sensitive)
local TOWERS = {
    LargeSpeakerTV = "Large Speaker TV Man",
    Zombie1 = "Zombie Dark Speakerman",
    Zombie2 = "Zombie Dark Speakerman 2",
    Zombie3 = "Zombie Dark Speakerman 3",
    ZombieMax = "Zombie Dark Speakerman max"
}

-- Tower costs
local TOWER_COSTS = {
    [TOWERS.LargeSpeakerTV] = 600,
    [TOWERS.Zombie1] = 1250,
    [TOWERS.Zombie2] = 3500,
    [TOWERS.Zombie3] = 6000,
    [TOWERS.ZombieMax] = 20000
}

-- Function to get player's current money
local function getMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local money = leaderstats:FindFirstChild("Money") or 
                      leaderstats:FindFirstChild("Cash") or 
                      leaderstats:FindFirstChild("Coins") or
                      leaderstats:FindFirstChild("💰")
        if money then
            return money.Value
        end
    end
    return nil
end

-- Function to check if we have enough money
local function hasEnoughMoney(towerName)
    local currentMoney = getMoney()
    if not currentMoney then
        return true
    end
    
    local cost = TOWER_COSTS[towerName] or 1000
    return currentMoney >= cost
end

-- Function to wait for money
local function waitForMoney(towerName, timeout)
    timeout = timeout or 60
    local startTime = tick()
    
    while tick() - startTime < timeout do
        if hasEnoughMoney(towerName) then
            return true
        end
        task.wait(1)
    end
    
    return false
end

-- Function to find a tower in Workspace
local function findTower(towerName)
    local towersFolder = workspace:FindFirstChild("Towers")
    if towersFolder then
        for _, tower in ipairs(towersFolder:GetChildren()) do
            if tower.Name == towerName then
                return tower
            end
        end
    end
    return nil
end

-- Function to get the current level of zombie tower
local function getZombieLevel()
    local levels = {
        [TOWERS.Zombie1] = 1,
        [TOWERS.Zombie2] = 2,
        [TOWERS.Zombie3] = 3,
        [TOWERS.ZombieMax] = 4
    }
    
    for towerName, level in pairs(levels) do
        if findTower(towerName) then
            return level, towerName
        end
    end
    
    return 0, nil
end

-- Function to spawn a tower (place new)
local function spawnTower(towerName, maxRetries)
    maxRetries = maxRetries or 3
    
    for attempt = 1, maxRetries do
        if not hasEnoughMoney(towerName) then
            print(string.format("  Waiting for money for %s...", towerName))
            waitForMoney(towerName, 30)
            if not hasEnoughMoney(towerName) then
                return false
            end
        end
        
        local moneyBefore = getMoney()
        
        local success, result = pcall(function()
            return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(towerName, towerCFrame)
        end)
        
        -- Wait for cooldown after placement
        task.wait(2)
        
        local moneyAfter = getMoney()
        
        if success and moneyAfter and moneyAfter < moneyBefore then
            print(string.format("  ✓ Spawned: %s (Money spent: %d, Left: %d)", towerName, moneyBefore - moneyAfter, moneyAfter))
            
            -- Verify tower exists in workspace
            task.wait(1)
            local tower = findTower(towerName)
            if tower then
                print(string.format("  ✓ Verified tower exists in Workspace/Towers: %s", towerName))
            else
                print(string.format("  ⚠ Tower not found in Workspace/Towers after spawn"))
            end
            
            return true
        elseif success then
            print(string.format("  ⚠ Spawn called but money unchanged - tower may already exist or on cooldown"))
            task.wait(3)
        else
            print(string.format("  ✗ Attempt %d/%d failed: %s", attempt, maxRetries, tostring(result)))
            task.wait(3)
        end
    end
    
    return false
end

-- Function to upgrade zombie (spawn higher level at same position)
local function upgradeZombie(currentLevel, targetTowerName)
    print(string.format("  Upgrading from level %d to %s...", currentLevel, targetTowerName))
    
    if not hasEnoughMoney(targetTowerName) then
        print(string.format("  Not enough money for %s", targetTowerName))
        return false
    end
    
    local moneyBefore = getMoney()
    
    -- Spawn the higher level tower at the same position
    local success, result = pcall(function()
        return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(targetTowerName, towerCFrame)
    end)
    
    task.wait(2) -- Cooldown
    
    local moneyAfter = getMoney()
    
    if success and moneyAfter and moneyAfter < moneyBefore then
        print(string.format("  ✓ Upgraded to: %s (Money spent: %d)", targetTowerName, moneyBefore - moneyAfter))
        
        -- Verify upgrade worked
        task.wait(1)
        local newTower = findTower(targetTowerName)
        if newTower then
            print(string.format("  ✓ Verified upgrade: %s now in Workspace/Towers", targetTowerName))
            return true
        else
            print(string.format("  ⚠ Upgrade completed but tower not found in Workspace/Towers"))
            return false
        end
    else
        print(string.format("  ✗ Upgrade failed for %s", targetTowerName))
        return false
    end
end

