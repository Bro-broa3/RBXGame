-- Function to get player's current money
local function getMoney()
    -- Try to find money value (adjust based on actual game)
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local cash = leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Coins")
        if cash then
            return cash.Value
        end
    end
    
    -- Alternative: Check player stats
    local stats = player:FindFirstChild("Stats")
    if stats then
        local money = stats:FindFirstChild("Money")
        if money then
            return money.Value
        end
    end
    
    return nil -- Money not found
end

-- Function to check if we have enough money (estimated costs)
local function hasEnoughMoney(towerName)
    local currentMoney = getMoney()
    if not currentMoney then
        print("⚠ Cannot read money value, proceeding anyway...")
        return true -- Proceed if can't read money
    end
    
    -- Estimated tower costs (adjust these based on actual game)
    local towerCosts = {
        ["Zombie Dark Speakerman"] = 100,
        ["Zombie Dark Speakerman 2"] = 300,
        ["Zombie Dark Speakerman 3"] = 600,
        ["Zombie Dark Speakerman Max"] = 1000,
        ["Large Speaker Tv Man"] = 150
    }
    
    local cost = towerCosts[towerName] or 100
    local hasMoney = currentMoney >= cost
    
    if not hasMoney then
        print("💰 Not enough money! Need: " .. cost .. ", Have: " .. currentMoney .. " - Waiting for more...")
    end
    
    return hasMoney
end

-- Function to spawn a tower with money check
local function spawnTower(towerName)
    -- Check if we have enough money
    if not hasEnoughMoney(towerName) then
        return false
    end
    
    local success, result = pcall(function()
        return game:GetService("ReplicatedStorage"):WaitForChild("Functions"):WaitForChild("SpawnTower"):InvokeServer(towerName, towerCFrame)
    end)
    
    if success then
        local money = getMoney()
        print("✓ Spawned: " .. towerName .. " (Money: " .. (money or "?") .. ")")
        return true
    else
        print("✗ Failed to spawn: " .. towerName .. " - " .. tostring(result))
        return false
    end
end

-- Function to upgrade zombie through levels (with money checks)
local function upgradeZombieToMax()
    print("  Upgrading zombie...")
    
    -- Spawn level 1
    if not spawnTower("Zombie Dark Speakerman") then
        return false
    end
    task.wait(0.5)
    
    -- Upgrade to level 2
    if not spawnTower("Zombie Dark Speakerman 2") then
        print("  ⚠ Not enough money for level 2, will retry later")
        return false
    end
    task.wait(0.5)
    
    -- Upgrade to level 3
    if not spawnTower("Zombie Dark Speakerman 3") then
        print("  ⚠ Not enough money for level 3, will retry later")
        return false
    end
    task.wait(0.5)
    
    -- Upgrade to Max
    if not spawnTower("Zombie Dark Speakerman Max") then
        print("  ⚠ Not enough money for Max level, will retry later")
        return false
    end
    
    print("  ✓ Fully upgraded to Max!")
    return true
end

-- Function to wait for money
local function waitForMoney(towerName, timeout)
    timeout = timeout or 30
    local startTime = tick()
    
    while tick() - startTime < timeout do
        if hasEnoughMoney(towerName) then
            return true
        end
        task.wait(1)
        print("  Waiting for money to spawn " .. towerName .. "...")
    end
    
    return false
end

